// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum ProjectCategory {
  RESIDENTIAL
  COMMERCIAL
  RESTAURANT
  KITCHEN
  BATHROOM
  INTERIOR
  EXTERIOR
  FURNITURE_CARPENTRY
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ServiceCategory {
  KITCHEN
  BATHROOM
  WHOLE_HOME
  RESTAURANT
  COMMERCIAL
  EXTERIOR
  CARPENTRY
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  password          String
  name              String
  role              UserRole       @default(OWNER)
  refreshToken      String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime?
  refreshTokens     RefreshToken[]
  
  @@map("users")
}

model Project {
  id              String          @id @default(uuid())
  title           String
  slug            String          @unique
  location        String?
  description     String          @db.Text
  category        ProjectCategory
  status          ProjectStatus   @default(DRAFT)
  displayOrder    Int             @default(0)
  featuredImageId String?         @unique
  completionDate  DateTime?
  clientName      String?
  isFeatured      Boolean         @default(false)
  tags            String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  publishedAt     DateTime?

  media           Media[]
  featuredImage   Media?          @relation("FeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)

  @@map("projects")
  @@index([category])
  @@index([status])
  @@index([displayOrder])
  @@index([slug])
  @@index([isFeatured])
}

model Media {
  id          String   @id @default(uuid())
  projectId   String?
  serviceId   String?
  type        String   // 'image' or 'video'
  filename    String
  originalName String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  duration    Int?     // For videos in seconds
  path        String   // Full path on filesystem
  url         String   // Public URL
  thumbnailPath String?
  thumbnailUrl String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service     Service?  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  featuredIn  Project? @relation("FeaturedImage")
  coverFor    Service?  @relation("ServiceCoverImage")
  heroFor     HomePage? @relation("HomePageHero")

  @@map("media")
  @@index([projectId])
  @@index([serviceId])
  @@index([type])
}

model Message {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  projectType String?
  budget      String?
  timeline    String?
  message     String   @db.Text
  isRead      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  isSpam      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("messages")
  @@index([isRead])
  @@index([isArchived])
  @@index([createdAt])
}

model Service {
  id              String           @id @default(uuid())
  title           String
  slug            String           @unique
  category        ServiceCategory
  shortDesc       String
  longDesc        String           @db.Text
  coverImageId    String?          @unique
  showOnHomepage  Boolean          @default(true)
  displayOrder    Int              @default(0)
  status          ContentStatus     @default(DRAFT)
  features        String[]
  benefits        String[]
  tags            String[]
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  publishedAt     DateTime?

  media           Media[]
  coverImage      Media?           @relation("ServiceCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  @@map("services")
  @@index([category])
  @@index([status])
  @@index([displayOrder])
  @@index([slug])
  @@index([showOnHomepage])
}

model Testimonial {
  id          String       @id @default(uuid())
  quote       String       @db.Text
  author      String
  location    String?
  rating      Int          @default(5)
  isFeatured  Boolean      @default(false)
  isVideo     Boolean      @default(false)
  videoUrl    String?
  status      ContentStatus @default(DRAFT)
  displayOrder Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  publishedAt DateTime?

  @@map("testimonials")
  @@index([status])
  @@index([isFeatured])
  @@index([displayOrder])
}

model SiteSettings {
  id                  String   @id @default(uuid())
  companyName         String
  tagline             String?
  ownerName           String
  email               String
  phone               String
  address             String?
  city                String?
  state               String?
  zip                 String?
  hours               String?
  logoUrl             String?
  faviconUrl          String?
  facebookUrl         String?
  instagramUrl        String?
  linkedinUrl         String?
  googleMapsUrl       String?
  metaTitle           String?
  metaDescription     String?
  googleAnalyticsId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("site_settings")
}

model HomePage {
  id                  String   @id @default(uuid())
  heroTitle           String
  heroSubtitle        String   @db.Text
  heroCtaText         String
  heroCtaLink         String
  heroImageId         String?  @unique
  statsTitle          String?
  statsSubtitle       String   @db.Text?
  servicesTitle       String
  servicesSubtitle    String   @db.Text
  projectsTitle       String
  projectsSubtitle    String   @db.Text
  testimonialsTitle   String
  testimonialsSubtitle String   @db.Text
  ctaTitle            String
  ctaSubtitle         String   @db.Text
  ctaButtonText       String
  ctaButtonLink       String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  heroImage           Media?   @relation("HomePageHero", fields: [heroImageId], references: [id], onDelete: SetNull)

  @@map("home_page")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("refresh_tokens")
  @@index([token])
  @@index([userId])
}
